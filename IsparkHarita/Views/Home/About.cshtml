@{
    ViewData["Title"] = "Hakkında";
    ViewData["Description"] = "İBB Otoparklar hakkında bilgi. Bu hizmet ile İstanbul'daki tüm İBB otoparklarının konumlarını, kapasitelerini ve detaylı bilgilerini görüntüleyebilirsiniz.";
}

<div class="about-container">
    <div class="about-content">
        <div class="about-header">
            <h1 class="about-title">İBB Otoparklar Hakkında</h1>
            <p class="about-subtitle">İstanbul Büyükşehir Belediyesi otopark bilgilerine kolayca erişin</p>
        </div>

        <div class="about-section">
            <div class="about-card">
                <div class="card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                </div>
                <h3>Otopark Bilgileri</h3>
                <p>Bu hizmet ile İstanbul'daki tüm İBB otoparklarının konumlarını, kapasitelerini, boş alan sayılarını ve detaylı bilgilerini görüntüleyebilirsiniz.</p>
            </div>

            <div class="about-card">
                <div class="card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                    </svg>
                </div>
                <h3>Harita Görünümü</h3>
                <p>Otoparkları harita üzerinde görüntüleyerek size en yakın otoparkı kolayca bulabilirsiniz. Her otopark için detaylı bilgilere erişebilir, Google Maps'de açabilirsiniz.</p>
            </div>

            <div class="about-card">
                <div class="card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                </div>
                <h3>Gelişmiş Filtreleme</h3>
                <p>Otopark adına göre arama yapabilir, boş alan durumuna, kapasite aralığına, boşluk oranına ve ilçeye göre filtreleme yapabilirsiniz.</p>
            </div>

            <div class="about-card">
                <div class="card-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                </div>
                <h3>İstatistikler</h3>
                <p>Detaylı istatistikler sayfasında toplam otopark sayısı, kapasite dağılımı, doluluk oranları ve daha fazlasını görüntüleyebilirsiniz.</p>
            </div>
        </div>

        <div class="about-footer">
            <div class="author-info">
