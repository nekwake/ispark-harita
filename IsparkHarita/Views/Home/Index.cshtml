@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["Description"] = "İBB Otoparklar hizmetinin tanıtım sayfası. İstanbul'daki tüm İBB otoparklarını harita üzerinden görüntüleyin, filtreleyin ve istatistikleri inceleyin.";
}

<section class="landing-hero-full">
    <div class="landing-hero-background">
        <img src="~/images/landing/landing-hero.svg" alt="" class="hero-bg-svg" aria-hidden="true" />
    </div>
    <div class="landing-hero-content">
        <div class="landing-hero-text">
            <h1 class="landing-title">İBB Otoparklar</h1>
            <p class="landing-subtitle">
                İstanbul Büyükşehir Belediyesi otoparklarını tek bir harita üzerinden gör,
                boş alan durumlarını anlık takip et, detaylı bilgilere hızla ulaş.
            </p>
            <div class="landing-actions">
                <a asp-controller="Home" asp-action="Harita" class="btn-primary-lg">Haritayı Aç</a>
                <a asp-controller="Home" asp-action="Istatistikler" class="btn-secondary-lg">İstatistikleri Gör</a>
            </div>
            <p class="landing-note">
                Canlı veriler doğrudan İBB sistemlerinden alınır. Harita ve istatistikler düzenli aralıklarla güncellenir.
            </p>
        </div>
    </div>
</section>

<div class="landing-container">

    <section class="landing-section">
        <h2 class="section-heading">Öne Çıkan Özellikler</h2>
        <div class="landing-features">
            <div class="landing-feature-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                </div>
                <h3>Harita Üzerinde Gör</h3>
                <p>İstanbul'daki tüm İBB otoparklarını tek bir harita üzerinde, kümelenmiş pinler ile performanslı şekilde görüntüleyin.</p>
            </div>
            <div class="landing-feature-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                    </svg>
                </div>
                <h3>Canlı Doluluk Bilgisi</h3>
                <p>Her otopark için anlık boş alan sayısını, kapasitesini ve doluluk oranını kolayca takip edin.</p>
            </div>
            <div class="landing-feature-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                </div>
                <h3>Gelişmiş Filtreleme</h3>
                <p>Boş alan durumuna, kapasite aralığına ve boşluk oranına göre filtreleme yaparak aradığınız otoparka hızla ulaşın.</p>
            </div>
            <div class="landing-feature-card">
                <div class="card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                </div>
                <h3>Detaylı İstatistikler</h3>
                <p>Toplam kapasite, doluluk oranları, kapasite dağılımı ve daha fazlasını istatistikler sayfasında inceleyin.</p>
            </div>
        </div>
    </section>

    <section class="landing-section">
        <h2 class="section-heading">Ekran Görüntüleri</h2>
        <div class="landing-gallery">
            <div class="landing-gallery-item">
                <img src="~/images/landing/screenshot-map.png" alt="Harita ve otopark listesi görünümü" class="gallery-image" />
                <p class="gallery-caption">Harita ve otopark listesi görünümü</p>
            </div>
            <div class="landing-gallery-item">
                <img src="~/images/landing/screenshot-filters.png" alt="Filtreleme ve arama paneli" class="gallery-image" />
                <p class="gallery-caption">Filtreleme ve arama paneli</p>
            </div>
            <div class="landing-gallery-item">
                <img src="~/images/landing/screenshot-stats.png" alt="Toplam kapasite ve doluluk istatistikleri" class="gallery-image" />
                <p class="gallery-caption">Toplam kapasite ve doluluk istatistikleri</p>
            </div>
        </div>
    </section>

    <section class="landing-section landing-cta-section">
        <div class="landing-cta-card">
            <div class="landing-cta-text">
                <h2>Hemen kullanmaya başlayın</h2>
                <p>İstanbul'daki İBB otoparklarını keşfetmek için harita görünümüne geçin, size en uygun otoparkı bulun.</p>
            </div>
            <div class="landing-cta-actions">
                <a asp-controller="Home" asp-action="Harita" class="btn-primary-lg">Haritayı Aç</a>
                <a asp-controller="Home" asp-action="About" class="btn-secondary-lg">Hizmet Hakkında</a>
            </div>
        </div>
    </section>
</div>